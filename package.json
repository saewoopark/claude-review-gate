{
  "name": "claude-review-gate",
  "displayName": "Claude Review Gate",
  "description": "Human-in-the-loop review gate for AI code changes: review native side-by-side diffs with inline comments in VS Code and feed Approve / Request-changes back to Claude Code, enforced automatically by a Stop hook.",
  "version": "0.11.0",
  "keywords": [
    "claude",
    "claude code",
    "code review",
    "review gate",
    "human-in-the-loop",
    "hooks",
    "diff",
    "ai"
  ],
  "publisher": "local-dev",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1b2233",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=18"
  },
  "categories": [
    "AI",
    "SCM Providers",
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "claudeReviewGate.approve",
        "title": "Review Gate: Approve file",
        "icon": "$(check)"
      },
      {
        "command": "claudeReviewGate.approveAll",
        "title": "Review Gate: Approve all files",
        "icon": "$(check-all)"
      },
      {
        "command": "claudeReviewGate.addComment",
        "title": "Add review comment"
      },
      {
        "command": "claudeReviewGate.status",
        "title": "Review Gate: Show status"
      },
      {
        "command": "claudeReviewGate.enableInClaudeCode",
        "title": "Review Gate: Enable for Claude Code"
      },
      {
        "command": "claudeReviewGate.disableInClaudeCode",
        "title": "Review Gate: Disable for Claude Code"
      }
    ],
    "menus": {
      "comments/commentThread/context": [
        {
          "command": "claudeReviewGate.addComment",
          "group": "inline"
        }
      ],
      "editor/title": [
        {
          "command": "claudeReviewGate.approve",
          "when": "resourceScheme == reviewgate",
          "group": "navigation@1"
        },
        {
          "command": "claudeReviewGate.approveAll",
          "when": "resourceScheme == reviewgate",
          "group": "navigation@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "claudeReviewGate.approve",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "claudeReviewGate.reviewActive && resourceScheme == reviewgate && !commentEditorFocused"
      }
    ],
    "configuration": {
      "title": "Claude Review Gate",
      "properties": {
        "claudeReviewGate.port": {
          "type": "number",
          "default": 7879,
          "description": "Local port the review gate listens on (the Stop hook talks to this)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node ./dist/test/run.js",
    "package": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.4.0"
  }
}
